# ─── ASR — 阴云 DashScope Paraformer ───────────────────────────────────────────
# 申请地址: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ASR 模型名称（可选，默认 paraformer-realtime-v2）
# 备选: paraformer-v2（离线识别更小误）
ASR_MODEL=paraformer-realtime-v2

# ─── LLM — DeepSeek ───────────────────────────────────────────────────────────
# 申请地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek 模型名称（可选，默认 deepseek-chat）
# 备选: deepseek-reasoner
LLM_MODEL=deepseek-chat

# ─── TTS — MiniMax ────────────────────────────────────────────────────────────
# 申请地址: https://platform.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=eyJhbGcixxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Group ID: 登录 MiniMax 控制台 → 账号信息 → 复制 Group ID
MINIMAX_GROUP_ID=17xxxxxxxxxxxxxxxxx

# TTS 模型名称（可选，默认 speech-01-turbo）
# 备选: speech-01-hd（更高质量，延迟稍高）
TTS_MODEL=speech-01-turbo

# 音色 ID — 从 MiniMax 音色列表中选择:
# 男声: male-qn-qingse（青涩）/ male-qn-jingying（精英）/ male-qn-badao（霸道）
# 女声: female-shaonv（少女）/ female-yujie（御姐）/ Ling（灵）
TTS_VOICE_ID=male-qn-badao
